generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  clerkId       String   @unique
  email         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  workouts      Workout[]
  trainingGoals TrainingGoal[]
  integrations  ConnectedIntegration[]
  generatedWorkouts GeneratedWorkout[]
}

model Workout {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept2Id      String?  @unique
  date            DateTime
  distanceMeters  Int
  timeSeconds     Int
  strokeRate      Int?
  calories        Int?
  heartRate       Int?
  workoutType     String?
  createdAt       DateTime @default(now())
}

model TrainingGoal {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalType    String   // weekly_distance, weekly_workouts, etc.
  target      Int
  current     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ConnectedIntegration {
  id           String @id @default(cuid())
  userId       String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String // 'concept2'
  accessToken  String
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([userId, provider])
}

model GeneratedWorkout {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                 String
  goal                  String
  durationMinutes       Int
  workoutType           String
  segments              Json
  coachingCues          String[]
  estimatedCalories     Int
  status                String    @default("generated")
  completedAt           DateTime?
  actualDurationSeconds Int?
  createdAt             DateTime  @default(now())
}
